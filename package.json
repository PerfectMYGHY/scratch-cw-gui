{
  "name": "scratch-gui",
  "version": "3.2.37",
  "description": "Graphical User Interface for creating and running Scratch 3.0 projects",
  "author": "Massachusetts Institute of Technology",
  "license": "GPL-3.0",
  "homepage": "https://github.com/LLK/scratch-gui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/LLK/scratch-gui.git"
  },
  "main": "./dist/scratch-gui.js",
  "scripts": {
    "edit:buildings:linux": "cp dist/js dist && bash move-chunks.sh",
    "edit:buildings": "copy dist\\js dist && move-chunks",
    "build:cp": "npm run clean && cross-env NODE_ENV=production SOURCEMAP=cheap-module-source-map webpack --colors --bail && copy-stuff",
    "build": "npm run clean && cross-env NODE_ENV=production SOURCEMAP=cheap-module-source-map webpack --colors --bail",
    "clean": "rimraf ./build && mkdirp build && rimraf ./dist && mkdirp dist",
    "deploy": "touch build/.nojekyll && gh-pages -t -d build -m \"[skip ci] Build for $(git log --pretty=format:%H -n1)\"",
    "prune": "./prune-gh-pages.sh",
    "i18n:push": "tx-push-src scratch-editor interface translations/en.json",
    "i18n:src": "rimraf ./translations/messages/src && babel src > tmp.js && rimraf tmp.js && build-i18n-src ./translations/messages/src ./translations/",
    "start": "webpack-dev-server",
    "test": "npm run test:lint && npm run test:unit && npm run build && npm run test:integration",
    "test:integration": "jest --maxWorkers=4 test[\\\\/]integration",
    "test:lint": "eslint . --ext .js,.jsx",
    "test:unit": "jest test[\\\\/]unit[\\\\/]addons",
    "test:smoke": "jest --runInBand test[\\\\/]smoke",
    "watch": "webpack --colors --watch"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
